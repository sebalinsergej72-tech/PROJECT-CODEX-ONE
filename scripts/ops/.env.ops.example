SMARTBRAIN_SUPABASE_DB_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require
SMARTBRAIN_N8N_BASE_URL=https://n8n.example.com
SMARTBRAIN_N8N_API_KEY=replace_me
SMARTBRAIN_N8N_ACTIVATE=true

# Optional service health verification
SMARTBRAIN_SERVICE_URL=https://smartbrain-service.example.com

# Optional settings initialization (applies on bootstrap)
SMARTBRAIN_INIT_SETTINGS=true
SMARTBRAIN_INIT_ENABLED=true
SMARTBRAIN_INIT_PAPER_MODE=true
SMARTBRAIN_INIT_RISK_LEVEL=medium
SMARTBRAIN_INIT_MAX_LEVERAGE=3
SMARTBRAIN_INIT_MAX_PORTFOLIO_RISK=0.02
SMARTBRAIN_INIT_MAX_DRAWDOWN_CIRCUIT=0.08
SMARTBRAIN_INIT_ASSETS=BTC,ETH
SMARTBRAIN_INIT_EMERGENCY_STOP=false
