# Supabase direct Postgres URL, for example:
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SMARTBRAIN_SUPABASE_DB_URL=

# n8n API endpoint and API key
SMARTBRAIN_N8N_BASE_URL=
SMARTBRAIN_N8N_API_KEY=

# Auto-activate imported workflows
SMARTBRAIN_N8N_ACTIVATE=true

# Optional service URL for health check
SMARTBRAIN_SERVICE_URL=

# Initialize/overwrite latest SmartBrain settings row
SMARTBRAIN_INIT_SETTINGS=true
SMARTBRAIN_INIT_ENABLED=true
SMARTBRAIN_INIT_PAPER_MODE=true
SMARTBRAIN_INIT_RISK_LEVEL=medium
SMARTBRAIN_INIT_MAX_LEVERAGE=3
SMARTBRAIN_INIT_MAX_PORTFOLIO_RISK=0.02
SMARTBRAIN_INIT_MAX_DRAWDOWN_CIRCUIT=0.08
SMARTBRAIN_INIT_ASSETS=BTC,ETH
SMARTBRAIN_INIT_EMERGENCY_STOP=false
