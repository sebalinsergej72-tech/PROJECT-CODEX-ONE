APP_ENV=development
APP_PORT=8000
SMARTBRAIN_API_KEY=replace_me

SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

HYPERLIQUID_PRIVATE_KEY=replace_me
HYPERLIQUID_ACCOUNT_ADDRESS=replace_me
HYPERLIQUID_USE_TESTNET=false

OPENAI_API_KEY=replace_me
GROK_API_KEY=replace_me
CRYPTOPANIC_API_KEY=replace_me
NEWS_API_KEY=replace_me
LUNARCRUSH_API_KEY=replace_me
COINGECKO_API_KEY=replace_me

INGEST_SYMBOLS=["BTC","ETH"]
INGEST_TIMEFRAMES=["1m","5m","15m","1h","4h","1d"]

MODEL_STORE_DIR=model_store
ONLINE_TREE_MIN_SAMPLES=100
ONLINE_TREE_WINDOW=5000
ONLINE_TREE_BOOST_ROUNDS=48
RL_REPLAY_MIN_SAMPLES=120
RL_REPLAY_WINDOW=5000
RL_REPLAY_STEPS=2000

BINANCE_PUBLIC_API=https://api.binance.com
BYBIT_PUBLIC_API=https://api.bybit.com

# Budget autonomous mode (single service)
INTERNAL_SCHEDULER_ENABLED=true
SCHEDULER_INGESTION_INTERVAL_MINUTES=5
SCHEDULER_DECISION_INTERVAL_MINUTES=1
SCHEDULER_RL_REPLAY_INTERVAL_MINUTES=30
SCHEDULER_TREE_INTERVAL_HOURS=1
SCHEDULER_DAILY_RETRAIN_HOUR_UTC=0
SCHEDULER_DAILY_RETRAIN_MINUTE_UTC=0
