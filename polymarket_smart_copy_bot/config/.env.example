# Core
APP_ENV=local
LOG_LEVEL=INFO
DEBUG=false
DRY_RUN=true
PORT=8000
TIMEZONE=UTC
RISK_MODE=aggressive

# Database: Railway injects DATABASE_URL automatically for Postgres
DATABASE_URL=

# Polymarket
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_HOST=https://data-api.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Auto-selected when empty: 1 if POLYMARKET_PROXY_ADDRESS is set, else 0 (EOA)
POLYMARKET_SIGNATURE_TYPE=
POLYMARKET_VERIFY_SSL=true

# Strategy
PRICE_MIN_CENTS=20
PRICE_MAX_CENTS=80
MAX_RISK_PER_TRADE=0.065
MAX_DAILY_RISK=0.07
MIN_QUALIFIED_WALLETS=5
MAX_QUALIFIED_WALLETS=12
MIN_WALLETS_AGGRESSIVE=3
MAX_WALLETS_AGGRESSIVE=15
MAX_PER_WALLET_PCT=0.15
MAX_PER_POSITION_PCT=0.10
MAX_TOTAL_EXPOSURE_PCT=0.65
KELLY_MULTIPLIER=2.0
DRAWDOWN_STOP_PCT=0.25
ENABLE_SHORT_TERM_MARKETS=true
DISABLE_PRICE_FILTER=true
AUTO_REINVEST=true
HIGH_CONVICTION_MULTIPLIER=1.5
WALLET_SCORE_REFRESH_HOURS=4
DISCOVERY_AUTOADD=true
DISCOVERY_MIN_TRADES_AGGRESSIVE=120
DISCOVERY_MIN_WINRATE_AGGRESSIVE=0.65
DISCOVERY_MIN_PROFIT_FACTOR_AGGRESSIVE=1.55
DISCOVERY_MIN_AVG_SIZE_AGGRESSIVE=350
DISCOVERY_MAX_DAYS_SINCE_LAST_TRADE_AGGRESSIVE=7
DISCOVERY_MAX_CONSEC_LOSSES_AGGRESSIVE=5
DISCOVERY_MIN_WALLET_AGE_AGGRESSIVE=30
DISCOVERY_MIN_TRADES_CONS=160
DISCOVERY_MIN_WINRATE_CONS=0.69
DISCOVERY_MIN_PROFIT_FACTOR_CONS=1.75
DISCOVERY_MIN_AVG_SIZE_CONS=550
DISCOVERY_MAX_DAYS_SINCE_LAST_TRADE_CONSERVATIVE=5
DISCOVERY_MAX_CONSEC_LOSSES_CONS=4
DISCOVERY_MIN_WALLET_AGE_CONS=45
TRADE_MONITOR_INTERVAL_SECONDS=60
PORTFOLIO_REFRESH_SECONDS=300
CAPITAL_RECALC_INTERVAL_MINUTES=60
MANUAL_CONFIRMATION_USD=250
DEFAULT_STARTING_EQUITY=70

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DASHBOARD_WRITE_TOKEN=
DASHBOARD_REFRESH_SECONDS=10

# Misc
WALLETS_CONFIG_PATH=config/wallets.yaml
