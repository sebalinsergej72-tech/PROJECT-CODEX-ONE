# Mirror of config/.env.example for convenience
APP_ENV=local
LOG_LEVEL=INFO
DEBUG=false
DRY_RUN=true
PORT=8000
DATABASE_URL=
RISK_MODE=aggressive
MAX_WALLETS_AGGRESSIVE=15
MAX_PER_WALLET_PCT=0.15
MAX_PER_POSITION_PCT=0.10
MAX_TOTAL_EXPOSURE_PCT=0.65
KELLY_MULTIPLIER=2.0
DRAWDOWN_STOP_PCT=0.25
DISABLE_PRICE_FILTER=true
ENABLE_SHORT_TERM_MARKETS=true
AUTO_REINVEST=true
DEFAULT_STARTING_EQUITY=70
DISCOVERY_AUTOADD=true
DISCOVERY_MIN_TRADES_AGGRESSIVE=120
DISCOVERY_MIN_WINRATE_AGGRESSIVE=0.65
DISCOVERY_MIN_PROFIT_FACTOR_AGGRESSIVE=1.55
DISCOVERY_MIN_AVG_SIZE_AGGRESSIVE=350
DISCOVERY_MAX_DAYS_SINCE_LAST_TRADE_AGGRESSIVE=7
DISCOVERY_MAX_CONSEC_LOSSES_AGGRESSIVE=5
DISCOVERY_MIN_WALLET_AGE_AGGRESSIVE=30
DISCOVERY_MIN_TRADES_CONS=160
DISCOVERY_MIN_WINRATE_CONS=0.69
DISCOVERY_MIN_PROFIT_FACTOR_CONS=1.75
DISCOVERY_MIN_AVG_SIZE_CONS=550
DISCOVERY_MAX_DAYS_SINCE_LAST_TRADE_CONSERVATIVE=5
DISCOVERY_MAX_CONSEC_LOSSES_CONS=4
DISCOVERY_MIN_WALLET_AGE_CONS=45
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNATURE_TYPE=
POLYMARKET_VERIFY_SSL=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_USERNAMES=
TELEGRAM_WEBAPP_SESSION_TTL_SECONDS=900
DASHBOARD_WRITE_TOKEN=
DASHBOARD_REFRESH_SECONDS=10
